# Cloudinary — Taco Express Peabody menu photos
# Copy to .env.local (never commit .env.local)

CLOUDINARY_CLOUD_NAME=drwvnkshg

# Option A: signed upload (Settings → API Keys in Cloudinary console)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Option B: unsigned upload preset (Settings → Upload → Upload presets → unsigned)
# CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# Massimo voice (COPY /voice page) — set in Vercel Production on taco-express-peabody ONLY
# Never put these on Martino Pasta Bar. Voice billing is a separate bill from the menu site.
# OPENAI_API_KEY=
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_SUPERVISOR_MODEL=gpt-5.6
# MEM0_API_KEY=   (optional — long-term memory by customer email)

# Taco Express Peabody VOICE Stripe (hands-free pay) — separate Stripe customer from Martino
# STRIPE_SECRET_KEY=
# TACO_VOICE_STRIPE_CUSTOMER_ID=cus_...
# TACO_VOICE_STRIPE_PAYMENT_METHOD_ID=pm_...
# TACO_VOICE_EMAIL_ALLOWLIST=frankamartino@gmail.com
# PUBLIC_BASE_URL=https://www.tacoexpresspeabody.com
#
# One-time card signup: https://www.tacoexpresspeabody.com/voice-signup
# Then paste customer/pm ids into Vercel env above.
